{
  "name": "english-learning-zoo",
  "outputDirectory": "code",
  "public": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/code/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
